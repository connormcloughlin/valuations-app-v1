{
  "openapi": "3.0.0",
  "info": {
    "title": "Valuations API - Dynamic UI Admin",
    "version": "1.0.0",
    "description": "Complete API documentation for Dynamic UI Configuration System"
  },
  "servers": [
    {
      "url": "https://localhost:5001",
      "description": "Development server (HTTPS)"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT Bearer token for API authentication"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Dynamic UI - Category Configuration",
      "description": "Manage category configurations for dynamic UI system"
    },
    {
      "name": "Dynamic UI - Field Management",
      "description": "Manage dynamic UI field configurations and validation"
    },
    {
      "name": "Dynamic UI - Dropdown Options",
      "description": "Manage dropdown options for dynamic fields"
    },
    {
      "name": "Dynamic UI - Statistics",
      "description": "Configuration statistics and analytics"
    },
    {
      "name": "Dynamic UI - Search and Filter",
      "description": "Search capabilities and configuration validation"
    },
    {
      "name": "Dynamic UI - Import/Export",
      "description": "Configuration import and export functionality"
    },
    {
      "name": "Dynamic UI - Validation",
      "description": "Configuration validation and error checking"
    },
    {
      "name": "Dynamic UI - Preview",
      "description": "Configuration preview and testing"
    },
    {
      "name": "Mobile APIs - Dynamic UI Config",
      "description": "Mobile-optimized dynamic UI configuration APIs with composite endpoints"
    }
  ],
  "paths": {
    "/api/admin/categories/{categoryId}/configuration": {
      "get": {
        "summary": "Get category configuration",
        "description": "Retrieve complete configuration for a specific category",
        "tags": [
          "Dynamic UI - Category Configuration"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "categoryId",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Category ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Configuration retrieved successfully"
          },
          "401": {
            "description": "Authentication required"
          },
          "404": {
            "description": "Category not found"
          }
        }
      },
      "put": {
        "summary": "Update category configuration",
        "description": "Update complete configuration for a specific category",
        "tags": [
          "Dynamic UI - Category Configuration"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "categoryId",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Category ID"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fields": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  },
                  "groupingStrategy": {
                    "type": "object"
                  },
                  "locationTemplates": {
                    "type": "array",
                    "items": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Configuration updated successfully"
          },
          "400": {
            "description": "Invalid request data"
          },
          "401": {
            "description": "Authentication required"
          },
          "404": {
            "description": "Category not found"
          }
        }
      }
    },
    "/api/admin/categories/bulk": {
      "post": {
        "summary": "Bulk category operations",
        "description": "Perform bulk operations on multiple categories",
        "tags": [
          "Dynamic UI - Category Configuration"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [
                      "enable",
                      "disable",
                      "update"
                    ]
                  },
                  "categoryIds": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk operation completed"
          },
          "400": {
            "description": "Invalid request parameters"
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/admin/fields/templates": {
      "get": {
        "summary": "Get field templates",
        "description": "Retrieve predefined field templates",
        "tags": [
          "Dynamic UI - Field Management"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Field templates retrieved successfully"
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/admin/fields/{fieldId}/duplicate": {
      "post": {
        "summary": "Duplicate field",
        "description": "Create a copy of an existing field with modifications",
        "tags": [
          "Dynamic UI - Field Management"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "fieldId",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Field ID to duplicate"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "newFieldName": {
                    "type": "string"
                  },
                  "targetCategoryId": {
                    "type": "integer"
                  },
                  "modifications": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Field duplicated successfully"
          },
          "400": {
            "description": "Invalid request parameters"
          },
          "401": {
            "description": "Authentication required"
          },
          "404": {
            "description": "Source field not found"
          }
        }
      }
    },
    "/api/admin/fields/bulk": {
      "post": {
        "summary": "Bulk field operations",
        "description": "Perform bulk operations on multiple fields",
        "tags": [
          "Dynamic UI - Field Management"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [
                      "enable",
                      "disable",
                      "toggle_visibility",
                      "update_required",
                      "delete"
                    ]
                  },
                  "fieldIds": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    }
                  },
                  "data": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk operation completed"
          },
          "400": {
            "description": "Invalid request parameters"
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/admin/fields/{fieldId}/toggle-visibility": {
      "post": {
        "summary": "Toggle field visibility",
        "description": "Toggle the display_on_ui property of a field",
        "tags": [
          "Dynamic UI - Field Management"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "fieldId",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Field ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Field visibility toggled successfully"
          },
          "401": {
            "description": "Authentication required"
          },
          "404": {
            "description": "Field not found"
          }
        }
      }
    },
    "/api/admin/dropdown-options/bulk": {
      "post": {
        "summary": "Bulk dropdown options operations",
        "description": "Create or update multiple dropdown options",
        "tags": [
          "Dynamic UI - Dropdown Options"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fieldId": {
                    "type": "integer"
                  },
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "dropdown_option_id": {
                          "type": "integer"
                        },
                        "option_value": {
                          "type": "string"
                        },
                        "option_label": {
                          "type": "string"
                        },
                        "display_order": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bulk operation completed"
          },
          "400": {
            "description": "Invalid request parameters"
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/admin/search": {
      "get": {
        "summary": "Global search",
        "description": "Search across all configuration entities",
        "tags": [
          "Dynamic UI - Search and Filter"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Search term"
          },
          {
            "in": "query",
            "name": "entity",
            "schema": {
              "type": "string",
              "enum": [
                "fields",
                "options",
                "strategies",
                "templates",
                "categories"
              ]
            },
            "description": "Entity type to search"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer",
              "default": 20
            },
            "description": "Results limit"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results retrieved"
          },
          "400": {
            "description": "Invalid search parameters"
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/admin/categories/{categoryId}/validate": {
      "get": {
        "summary": "Validate category configuration",
        "description": "Check for configuration errors and inconsistencies",
        "tags": [
          "Dynamic UI - Validation"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "categoryId",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Category ID to validate"
          }
        ],
        "responses": {
          "200": {
            "description": "Validation completed"
          },
          "401": {
            "description": "Authentication required"
          },
          "404": {
            "description": "Category not found"
          }
        }
      }
    },
    "/api/admin/categories/{categoryId}/preview": {
      "get": {
        "summary": "Preview category configuration",
        "description": "Generate a preview of how the category will appear",
        "tags": [
          "Dynamic UI - Preview"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "categoryId",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Category ID to preview"
          }
        ],
        "responses": {
          "200": {
            "description": "Preview generated successfully"
          },
          "401": {
            "description": "Authentication required"
          },
          "404": {
            "description": "Category not found"
          }
        }
      }
    },
    "/api/admin/categories/{categoryId}/export": {
      "get": {
        "summary": "Export category configuration",
        "description": "Export complete category configuration",
        "tags": [
          "Dynamic UI - Import/Export"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "categoryId",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Category ID to export"
          },
          {
            "in": "query",
            "name": "format",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "csv"
              ],
              "default": "json"
            },
            "description": "Export format"
          }
        ],
        "responses": {
          "200": {
            "description": "Configuration exported successfully"
          },
          "401": {
            "description": "Authentication required"
          },
          "404": {
            "description": "Category not found"
          }
        }
      }
    },
    "/api/admin/categories/import": {
      "post": {
        "summary": "Import category configuration",
        "description": "Import category configuration from JSON",
        "tags": [
          "Dynamic UI - Import/Export"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "targetCategoryId": {
                    "type": "integer"
                  },
                  "configurationData": {
                    "type": "object"
                  },
                  "importOptions": {
                    "type": "object",
                    "properties": {
                      "overwriteExisting": {
                        "type": "boolean",
                        "default": false
                      },
                      "importFields": {
                        "type": "boolean",
                        "default": true
                      },
                      "importStrategies": {
                        "type": "boolean",
                        "default": true
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Configuration imported successfully"
          },
          "400": {
            "description": "Invalid import data"
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/admin/statistics/usage": {
      "get": {
        "summary": "Get comprehensive usage statistics",
        "description": "Detailed analytics on field usage and category performance",
        "tags": [
          "Dynamic UI - Statistics"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "timeframe",
            "schema": {
              "type": "string",
              "enum": [
                "week",
                "month",
                "quarter",
                "year"
              ],
              "default": "month"
            },
            "description": "Time period for statistics"
          },
          {
            "in": "query",
            "name": "categoryId",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by specific category"
          }
        ],
        "responses": {
          "200": {
            "description": "Usage statistics retrieved"
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
    "/api/admin/statistics/performance": {
      "get": {
        "summary": "Get performance analytics",
        "description": "Performance metrics for forms and user interactions",
        "tags": [
          "Dynamic UI - Statistics"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Performance analytics retrieved"
          },
          "401": {
            "description": "Authentication required"
          }
        }
      }
    },
