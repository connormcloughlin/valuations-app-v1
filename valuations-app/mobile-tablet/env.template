# Environment Configuration Template
# Copy to .env.development, .env.staging, or .env.production (or set ENV_FILE in eas.json).
# Entra split runbook: valuations-api repo docs/entra-test-prod-split-runbook.md

# API Configuration (per EAS profile / APP_ENV)
# development: local or dev API URL
# staging: test Container App FQDN
# production: prod Container App FQDN
API_BASE_URL=https://ca-valuations-api-test.example.azurecontainerapps.io/api
API_TIMEOUT=45000

# Azure AD — single mobile app registration for all flavors (Valuations Mobile Tablet App)
AZURE_MOBILE_CLIENT_ID=add1ac1d-0559-485d-b590-8d59a2907178
AZURE_TENANT_ID=your-azure-tenant-id

# API resource app (audience for access tokens) — MUST match environment:
# development + staging: Test API (486ce186-59ce-4305-b2bd-75f94b4bb69b)
# production: Prod API (<NEW_PROD_CLIENT_ID> after Entra split)
AZURE_API_CLIENT_ID=486ce186-59ce-4305-b2bd-75f94b4bb69b

# OAuth redirect: interactive login uses app.config.js scheme + path "auth" (see azureAdService.ts).
# Register these on the mobile Entra app (SPA/mobile redirect URIs), not HTTPS API URLs:
#   development: valuations-app-dev://auth
#   staging:     valuations-app-staging://auth
#   production:  valuations-app://auth
# AZURE_REDIRECT_URI is required at startup; set to the matching scheme URI for the file you copy.
AZURE_REDIRECT_URI=valuations-app-staging://auth

# API Key Authentication Configuration
API_KEY=your-api-key-here
API_KEY_HEADER_NAME=X-API-Key
USER_CONTEXT_HEADER_NAME=X-User-Context

# Debug Configuration
DEBUG_MODE=true
LOG_LEVEL=debug
